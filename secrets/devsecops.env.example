# Copy this file to secrets/devsecops.env and fill the real values.
# This file is only a template and can be committed.
# The real secrets/devsecops.env file is ignored by .gitignore.

#
# SonarQube / SonarCloud
#
# Example:
# SONAR_HOST_URL=https://sonarcloud.io
# SONAR_TOKEN=xxxxxxxxxxxxxxxxxxxx
# SONAR_PROJECT_KEY=tcc-devsecops-lab
SONAR_HOST_URL=
SONAR_TOKEN=
SONAR_PROJECT_KEY=tcc-devsecops-lab

#
# Container registry
#
# For GHCR example:
# REGISTRY=ghcr.io
# REGISTRY_IMAGE=ghcr.io/<github-user-or-org>/juice-shop-lab
# REGISTRY_USER=<github-user>
# REGISTRY_PASSWORD=<token-or-password>
REGISTRY=ghcr.io
REGISTRY_IMAGE=
REGISTRY_USER=
REGISTRY_PASSWORD=

#
# GitHub repository metadata
#
# Example:
# GITHUB_REPOSITORY=<owner>/<repo>
# GITHUB_DEFAULT_BRANCH=main
GITHUB_REPOSITORY=
GITHUB_DEFAULT_BRANCH=main

#
# Kubernetes deployment parameters
#
K8S_NAMESPACE=devsecops-lab
K8S_INGRESS_HOST=juice-shop.local

#
# Optional CI deploy settings
#
# Set ENABLE_CI_DEPLOY=true only after repository secrets and cluster access are ready.
ENABLE_CI_DEPLOY=false
