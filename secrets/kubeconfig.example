# Do not put real credentials in this example file.
# If you want to provide a dedicated kubeconfig copy for automation,
# create secrets/kubeconfig with your real content.
#
# Suggested source on your machine:
#   ~/.kube/config
#
# Suggested usage:
#   export KUBECONFIG="$(pwd)/secrets/kubeconfig"
#
# Keep the real file local only. It is ignored by .gitignore.
